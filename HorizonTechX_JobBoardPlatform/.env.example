# Server
NODE_ENV=development
PORT=5000

# MongoDB
# Local:      mongodb://127.0.0.1:27017/horizontechx_jobboard
# Atlas:      mongodb+srv://<user>:<password>@cluster0.mongodb.net/horizontechx_jobboard
MONGO_URI=mongodb://127.0.0.1:27017/horizontechx_jobboard

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# File Uploads
MAX_RESUME_SIZE_MB=5

# Admin bootstrap (used by seed script)
ADMIN_EMAIL=admin@horizontechx.com
ADMIN_PASSWORD=Admin@12345

# CORS
CLIENT_ORIGIN=http://localhost:3000
