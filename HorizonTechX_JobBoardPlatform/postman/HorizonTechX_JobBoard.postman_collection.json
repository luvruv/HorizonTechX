{
  "info": {
    "name": "HorizonTechX Job Board Platform",
    "description": "API collection for the Job Board Platform backend (Express + MongoDB). Set the {{baseUrl}}, {{employerToken}}, {{candidateToken}}, and {{adminToken}} collection variables after logging in.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "employerToken", "value": "" },
    { "key": "candidateToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "jobId", "value": "" },
    { "key": "resumeId", "value": "" },
    { "key": "applicationId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Employer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register/employer",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Sharma\",\n  \"companyName\": \"NimbusTech Solutions\",\n  \"email\": \"hr@nimbustech.com\",\n  \"password\": \"Password@123\",\n  \"phone\": \"9876543210\",\n  \"companyDescription\": \"Cloud infra SaaS company\",\n  \"industry\": \"IT\",\n  \"location\": \"Gurugram, India\"\n}"
            }
          }
        },
        {
          "name": "Register Candidate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register/candidate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dhruva Jhanjhari\",\n  \"email\": \"dhruva.demo@example.com\",\n  \"password\": \"Password@123\",\n  \"skills\": [\"javascript\", \"react\", \"node.js\", \"mongodb\"],\n  \"experienceYears\": 1,\n  \"location\": \"Gurugram, India\"\n}"
            }
          }
        },
        {
          "name": "Login (Employer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hr@nimbustech.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"employer\"\n}"
            }
          }
        },
        {
          "name": "Login (Candidate)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dhruva.demo@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"candidate\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@horizontechx.com\",\n  \"password\": \"Admin@12345\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{candidateToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employerToken}}" }
            ],
            "url": "{{baseUrl}}/jobs",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Backend Developer Intern\",\n  \"description\": \"Build REST APIs with Node & MongoDB\",\n  \"location\": \"Gurugram, India\",\n  \"jobType\": \"internship\",\n  \"category\": \"Engineering\",\n  \"experienceLevel\": \"entry\",\n  \"skillsRequired\": [\"node.js\", \"mongodb\", \"express\"],\n  \"salaryMin\": 15000,\n  \"salaryMax\": 25000,\n  \"isRemote\": true\n}"
            }
          }
        },
        {
          "name": "Search Jobs (filters)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs?keyword=developer&location=Gurugram&jobType=internship&skills=node.js,mongodb&salaryMin=10000&page=1&limit=10&sort=-createdAt"
          }
        },
        {
          "name": "Get Job By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/jobs/{{jobId}}" }
        },
        {
          "name": "Update Job",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employerToken}}" }
            ],
            "url": "{{baseUrl}}/jobs/{{jobId}}",
            "body": { "mode": "raw", "raw": "{\n  \"salaryMax\": 30000\n}" }
          }
        },
        {
          "name": "Update Job Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employerToken}}" }
            ],
            "url": "{{baseUrl}}/jobs/{{jobId}}/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"closed\"\n}" }
          }
        },
        {
          "name": "Delete Job",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{employerToken}}" }],
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        }
      ]
    },
    {
      "name": "Resumes",
      "item": [
        {
          "name": "Upload Resume",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{candidateToken}}" }],
            "url": "{{baseUrl}}/resumes/upload",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "resume", "type": "file", "src": [] }]
            }
          }
        },
        {
          "name": "My Resumes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{candidateToken}}" }],
            "url": "{{baseUrl}}/resumes/my"
          }
        },
        {
          "name": "Set Default Resume",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{candidateToken}}" }],
            "url": "{{baseUrl}}/resumes/{{resumeId}}/default"
          }
        },
        {
          "name": "Delete Resume",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{candidateToken}}" }],
            "url": "{{baseUrl}}/resumes/{{resumeId}}"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Apply To Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{candidateToken}}" }
            ],
            "url": "{{baseUrl}}/applications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": \"{{jobId}}\",\n  \"coverLetter\": \"I would love to join your team.\"\n}"
            }
          }
        },
        {
          "name": "My Applications (Candidate tracking)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{candidateToken}}" }],
            "url": "{{baseUrl}}/applications/my"
          }
        },
        {
          "name": "Applications For Job (Employer view)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{employerToken}}" }],
            "url": "{{baseUrl}}/applications/job/{{jobId}}"
          }
        },
        {
          "name": "Update Application Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employerToken}}" }
            ],
            "url": "{{baseUrl}}/applications/{{applicationId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"under_review\",\n  \"note\": \"Shortlisted for phone screen\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "My Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{employerToken}}" }],
            "url": "{{baseUrl}}/notifications/my"
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{employerToken}}" }],
            "url": "{{baseUrl}}/notifications/read-all"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Overview Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/stats/overview"
          }
        },
        {
          "name": "Applications Funnel",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/stats/applications-funnel"
          }
        },
        {
          "name": "Top Employers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/stats/top-employers"
          }
        },
        {
          "name": "Verify Employer",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/employers/EMPLOYER_ID/verify",
            "body": { "mode": "raw", "raw": "{\n  \"isVerified\": true\n}" }
          }
        }
      ]
    }
  ]
}
