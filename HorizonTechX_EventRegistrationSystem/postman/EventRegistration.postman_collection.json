{
  "info": {
    "name": "HorizonTechX Event Registration",
    "description": "API collection for Event Registration System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}" },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"organizer@example.com\",\n  \"password\": \"organizer123\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Events (paginated)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/events?page=1&limit=10" }
        },
        {
          "name": "Search Events",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/events?search=Tech&venue=Mumbai&status=upcoming" }
        },
        {
          "name": "Get Event by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/events/1" }
        },
        {
          "name": "Create Event (Organizer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"New Workshop\",\n  \"description\": \"Hands-on coding\",\n  \"location\": \"Room 101\",\n  \"date\": \"2026-11-20T09:00:00\",\n  \"capacity\": 30\n}" },
            "url": "{{baseUrl}}/api/events"
          }
        },
        {
          "name": "My Events (Organizer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/events/my-events"
          }
        }
      ]
    },
    {
      "name": "Registrations",
      "item": [
        {
          "name": "Register for Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/events/1/register"
          }
        },
        {
          "name": "My Registrations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/me/registrations"
          }
        },
        {
          "name": "Event Registrations (Organizer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/events/1/registrations"
          }
        },
        {
          "name": "Cancel Registration",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/registrations/1"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" }
  ]
}
